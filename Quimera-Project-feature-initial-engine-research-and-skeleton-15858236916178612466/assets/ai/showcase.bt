<root BTCPP_format="4">
    <BehaviorTree ID="MainTree">
        <Sequence name="SentinelPatrol">
            <Fallback name="CheckStatus">
                <Condition ID="IsCoreStable" />
                <Action ID="AlertSentinels" />
            </Fallback>
            <Action ID="MoveToNextWaypoint" />
            <Action ID="ScanArea" />
            <AlwaysSuccess />
        </Sequence>
    </BehaviorTree>
</root>
